# Copy this file to .env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=sk-ant-...

# Twilio (used by src/server.js for sending/receiving SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567

# Local server port
PORT=3000

# Admin dashboard (https://your-url/admin) — username is "admin"
ADMIN_PASSWORD=change-me

# Optional: Google Calendar sync. Also set google_calendar.calendar_id in
# config.json. Provide ONE of the following with a service account that has
# "Make changes to events" access on that calendar:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'   # full key file contents, one line
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/path/to/service-account.json
